@inject ProtectedLocalStorage protectedLocalStorage
@inject NavigationManager NavigationManager
@page "/addentry"
<PageTitle>Add Entry</PageTitle>
<h3>Add Entry</h3>

<EditForm Model="@entry">
    <div class="mb-3">
        Name:
        <InputText @bind-Value="entry.name" />
    </div>
    <div class="mb-3">
        @foreach (ETypes types in Enum.GetValues(typeof(ETypes)))
        {
            if(types != ETypes.None)
            {
                <input type="radio" name="EntertainmentType" value="@types" @onchange="RadioSelection" />
                <label class="form-check-label">@types &nbsp;</label>
            }
        }

    </div>
    <div class="mb-3">  
        Rating
        <InputSelect class="form-select" @bind-value="entry.rating">
            
            @for (int i = 1; i <= 10;  i++)
            {
                <option Value="@i" class="form-check-input">@i</option>
            }
        </InputSelect>
    </div>
    <div class="mb-3">
        Genre
        <InputSelect class="form-select" @bind-value="entry.genre">
            @if(genres != null)
            {
                <option Value="" class="form-check-input"></option>
                @foreach (string genre in genres)
                {
                    <option @key="@genre" Value="@genre" class="form-check-input">@genre</option>
                }
            }           
        </InputSelect>
    </div>
    
    <div class="mb-3">
        Add new genre:
        <InputText @bind-Value="newGenre" />
        <button class="btn btn-primary" @onclick="@AddNewGenre">Add new genre</button>
        <button class="btn btn-primary" @onclick="@DeleteGenre">Delete the above selected genre</button>
    </div>

    <div class="mb-3">
        Shelf
        <InputSelect class="form-select" @bind-value="entry.shelf">           
            @if (shelves != null)
            {
                <option Value="" class="form-check-input"></option>
                @foreach (string shelf in shelves)
                {
                    <option @key="@shelf" Value="@shelf" class="form-check-input">@shelf</option>
                }
            }
        </InputSelect>
    </div>
    <div class="mb-3">
        Add new shelf:
        <InputText @bind-Value="newShelf" />
        <button class="btn btn-primary" @onclick="@AddNewShelf">Add new shelf</button>
        <button class="btn btn-primary" @onclick="@DeleteShelf">Delete the above selected shelf</button>
    </div>

    <button class="btn btn-primary" @onclick="@StoreEntryLocal">Add entry</button>
</EditForm>



@code {
    Entry entry = new Entry();
    List<string> genres = new List<string>();
    string newGenre = "";
    List<string> shelves = new List<string>();
    string newShelf = "";


    protected override async Task OnInitializedAsync()
    {
        await UpdateGenres();
        await UpdateSheves();
    }

    private async Task RadioSelection(ChangeEventArgs args)
    {
        entry.type = Enum.Parse<ETypes>(args.Value.ToString());
        await UpdateGenres();
        await UpdateSheves();
    }

    // Genres
    private async Task UpdateGenres()
    {
        var result = await protectedLocalStorage.GetAsync<List<string>>("genres" + entry.type.ToString());
        if(result.Value == null)
            genres = new List<string>();
        else
            genres = result.Value;
    }

    private async Task AddNewGenre()
    {
        await UpdateGenres();
        if (!genres.Contains(newGenre) && entry.type != ETypes.None)
        {
            genres.Add(newGenre);
            await StoreGenresLocal();
        }       
    }

    private async Task StoreGenresLocal()
    {
        await protectedLocalStorage.SetAsync("genres" + entry.type.ToString(), genres);
    }

    private async Task DeleteGenre()
    {
        if (entry.genre != null)
        {
            genres.Remove(entry.genre);
            if (genres.Count == 0)
                await protectedLocalStorage.DeleteAsync("genres" + entry.type.ToString());
            else
                await protectedLocalStorage.SetAsync("genres" + entry.type.ToString(), genres);
        }
    }

    // Shelves
    private async Task UpdateSheves()
    {
        var result = await protectedLocalStorage.GetAsync<List<string>>("shelves" + entry.type.ToString());
        if (result.Value == null)
            shelves = new List<string>();
        else
            shelves = result.Value;
    }

    private async Task AddNewShelf()
    {
        await UpdateSheves();
        if (!shelves.Contains(newShelf) && entry.type != ETypes.None)
        {
            shelves.Add(newShelf);
            await StoreShelvesLocal();
        }
    }

    private async Task StoreShelvesLocal()
    {
        await protectedLocalStorage.SetAsync("shelves" + entry.type.ToString(), shelves);
    }

    private async Task DeleteShelf()
    {
        if (entry.shelf != null)
        {
            shelves.Remove(entry.shelf);
            if (shelves.Count == 0)
                await protectedLocalStorage.DeleteAsync("shelves" + entry.type.ToString());
            else
                await protectedLocalStorage.SetAsync("shelves" + entry.type.ToString(), shelves);
        }
    }

    // Store Entry
    private async Task StoreEntryLocal()
    {
        await protectedLocalStorage.SetAsync(entry.id.ToString(), entry);
    }
    
}
